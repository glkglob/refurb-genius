# Dependencies — local install only; never commit
node_modules/
**/node_modules/
.pnpm-store/

# Build / framework output — generated by local build, CI, or the host
dist/
dist-ssr/
build/
.output/
.vercel/
.tanstack/
.turbo/
.vinxi/
.nitro/

# Testing
coverage/
playwright-report/
test-results/

# TypeScript
*.tsbuildinfo

# Environment secrets — never commit real env files
.env
.env.local
.env.*.local
.env*.local
!.env.example

# Logs
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Operating systems and editors
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.claude/settings.local.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Wrangler / Cloudflare
.wrangler/
.dev.vars

# Supabase local temp
supabase/.temp/

# External tools & experiments (not part of the product monorepo)
backend/
property-intel/

# npm lockfile — this repo uses pnpm (pnpm-lock.yaml)
package-lock.json
