# Supabase connection (server-side + client-side)
SUPABASE_URL=https://sxhzjmzfkgbogmlsbeju.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Vite client-side env vars (standard Supabase naming — preferred for Vercel deployments)
VITE_SUPABASE_URL=https://sxhzjmzfkgbogmlsbeju.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Lovable Cloud alias — accepted as fallback if VITE_SUPABASE_ANON_KEY is absent
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# Public site URL — used for og:url and og:image absolute paths.
# Set this in Vercel project settings for BOTH production and preview environments.
# Production: https://www.refurbgenius.info
# Preview: your Vercel preview URL (e.g. https://refurb-genius-git-branch.vercel.app)
VITE_PUBLIC_URL=https://www.refurbgenius.info

# Sentry error monitoring (optional — leave blank to disable)
VITE_SENTRY_DSN=
# Sentry source map uploads (CI / Vercel build-time only — never exposed to the browser)
# Get from: sentry.io → Settings → Auth Tokens (needs project:releases + org:read)
# Production policy (vite.vercel.config.ts):
# - sourcemap: "hidden" when these are set (no //# sourceMappingURL in public JS)
# - maps uploaded privately to Sentry, then deleted from .vercel/output/static
# - if token/org/project missing, client source maps are not generated at all
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug

# Optional: Enable recording of full AI/LLM inputs and outputs in Sentry spans.
# Use only temporarily for debugging agent behavior (prompts contain property details).
# Default: false (privacy-safe). See src/lib/sentry.ts and openai-client.ts.
SENTRY_AI_RECORD_DATA=false

# OpenAI API integration (optional — leave blank to disable real photo/redesign analysis)
# Note: This must be a server-only variable. Do NOT expose via VITE_ prefix to browser.
# All OpenAI API calls must go through server/runtime handlers only.
OPENAI_API_KEY=your-openai-api-key-here

# AI Vision Provider Selection (optional):
# - "openai" — use OpenAI gpt-4o (default if configured)
# - "huggingface" — use HuggingFace models (Llama 3.2 Vision, Qwen2-VL, Pixtral, etc.)
# - "auto" (default) — prefer OpenAI if key present, else HuggingFace if configured
AI_VISION_PROVIDER=auto

# Hugging Face integration (optional — alternative to OpenAI for vision + text)
# Use either HF Inference API (apiKey) OR self-hosted TGI/vLLM (baseUrl)
# Note: These are server-only variables. Do NOT expose via VITE_ prefix.
HUGGINGFACE_API_KEY=your-hf-api-key-here
# Optional: self-hosted endpoint (e.g., http://localhost:8080 or your TGI/vLLM URL)
HUGGINGFACE_ENDPOINT_URL=
# Optional: vision model (default: meta-llama/Llama-3.2-11B-Vision-Instruct)
# Options: meta-llama/Llama-3.2-11B-Vision-Instruct, meta-llama/Llama-3.2-90B-Vision-Instruct,
#          Qwen/Qwen2-VL-7B-Instruct, mistralai/Pixtral-12B-2409, HuggingFaceTB/SmolVLM-Instruct
HF_VISION_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct
# Optional: text model for scope/estimate (default: meta-llama/Meta-Llama-3.1-8B-Instruct)
HF_TEXT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# Optional: request timeout in ms (default: 60000)
HF_TIMEOUT_MS=60000

# Admin bootstrap credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YOUR_SECURE_PASSWORD

# Optional: direct Postgres connection for bootstrap (bypasses PostgREST schema cache).
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI).
# DATABASE_URL=postgresql://postgres.sxhzjmzfkgbogmlsbeju:YOUR_DB_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# Resend (email sending for Trades Marketplace notifications)
# Used by the Supabase Edge Function: send-notification-email
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_key_here

# Apple Sign in with Apple (optional — for Apple OAuth)
# Get from Apple Developer Console → Certificates, Identifiers & Profiles → Identifiers → Services ID
VITE_APPLE_CLIENT_ID=your-apple-services-id
