# Supabase connection (server-side + client-side)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Vite client-side env vars (standard Supabase naming — preferred for Vercel deployments)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Lovable Cloud alias — accepted as fallback if VITE_SUPABASE_ANON_KEY is absent
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# Public site URL — used for og:url and og:image absolute paths.
# Set this in Vercel project settings for BOTH production and preview environments.
# Production: https://www.refurbgenius.site
# Preview: your Vercel preview URL (e.g. https://refurb-genius-git-branch.vercel.app)
VITE_PUBLIC_URL=https://www.refurbgenius.site

# Sentry error monitoring (optional — leave blank to disable)
VITE_SENTRY_DSN=

# OpenAI API integration (optional — leave blank to disable real photo/redesign analysis)
# Note: This must be a server-only variable. Do NOT expose via VITE_ prefix to browser.
# All OpenAI API calls must go through server/runtime handlers only.
OPENAI_API_KEY=

# Admin bootstrap credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YOUR_SECURE_PASSWORD

# Optional: direct Postgres connection for bootstrap (bypasses PostgREST schema cache).
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI).
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
