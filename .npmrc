# pnpm configuration for Refurb Genius (TanStack Start + Supabase monorepo)
# See also: package.json "packageManager" and "pnpm.onlyBuiltDependencies"
# Purpose: ensure reproducible installs across local dev, GitHub CI, and Vercel.

# Use exact pnpm version declared in package.json (via corepack / vercel / action-setup)
# This avoids pnpmfileChecksum / lockfile config mismatches from version skew.

auto-install-peers=true
strict-peer-dependencies=false

# Note: onlyBuiltDependencies (in package.json) replaced the previous .pnpmfile.cjs hook
# which was causing ERR_PNPM_LOCKFILE_CONFIG_MISMATCH on Vercel.
